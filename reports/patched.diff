+def _repair_cached_attention_mask(
+    attention_mask,
+    inputs_embeds,
+    wrapped_cache_params,
+):
+    if (
+        wrapped_cache_params is None
+        or attention_mask is None
+        or inputs_embeds is None
+    ):
+        return attention_mask
+
+    past_len = wrapped_cache_params.get_seq_length()
+    current_len = inputs_embeds.shape[1]
+    mask_len = attention_mask.shape[-1]
+
+    logger.warning(f'[MaskRepair] Entry - past_len: {past_len}, current_len: {current_len}, mask_len: {mask_len}, mask_shape: {attention_mask.shape}')
+
+    if past_len > 0 and mask_len == current_len:
+        logger.warning(f'[MaskRepair] Condition Met: Concat triggered.')
+        past_mask = torch.ones(
+            attention_mask.shape[0],
+            past_len,
+            dtype=attention_mask.dtype,
+            device=attention_mask.device,
+        )
+        attention_mask = torch.cat([past_mask, attention_mask], dim=-1)
+        logger.warning(f'[MaskRepair] Final mask shape: {attention_mask.shape}')
+    else:
+        logger.warning(f'[MaskRepair] Condition Failed: Skipping Concat.')
+        
+    return attention_mask
